<Window x:Class="KeyDisabler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Key Disabler"
        Width="1320"
        Height="760"
        MinWidth="1120"
        MinHeight="700"
        Background="{DynamicResource WindowBackground}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image x:Name="AboutLogoImage" Width="72" Height="72" Stretch="Uniform" Margin="0,0,18,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Key Disabler" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock Text="Block broken keys, remap healthy keys, and test each physical keyboard safely."
                               FontSize="15"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="22,12"
                    MinWidth="270"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="↻" FontSize="24" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusPill" Text="Ready" Foreground="{DynamicResource PrimaryBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="Transparent">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌂" FontSize="18" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="Dashboard" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <UniformGrid Columns="5" Margin="0,8,0,18">
                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⌨" FontSize="40" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="ConnectedDevicesCountText" Text="0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Connected Devices" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Devices detected" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🛡" FontSize="40" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="ActiveBlockRulesCountText" Text="0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Active Block Rules" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Keys are being blocked" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⇄" FontSize="42" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="ActiveRemapRulesCountText" Text="0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Active Remap Rules" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Keys are being remapped" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⌨×" FontSize="36" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="DisabledKeyboardsCountText" Text="0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Fully Disabled Keyboards" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Keyboards disabled" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="✓" FontSize="48" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,18,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Driver Status" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock x:Name="DriverStatusValueText" Text="Checking" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,4,0,0" />
                                        <TextBlock x:Name="DriverStatusDetailText" Text="Driver status" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <TextBlock Text="⌁" FontSize="34" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Current keyboard event" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Click 'Start Detect Keys' to monitor key presses. The app will show which keyboard produced the key and whether it was blocked."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="14"
                                               Margin="58,0,0,20" />
                                    <Button x:Name="ToggleDetectKeysButton" Click="ToggleDashboardDetection_Click" Margin="58,0,0,18" Padding="20,14" FontSize="16" FontWeight="SemiBold" Background="{DynamicResource PrimaryDeepBrush}" BorderBrush="{DynamicResource PrimaryBrush}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="▶" Margin="0,0,12,0" />
                                            <TextBlock Text="Start Detect Keys" />
                                        </StackPanel>
                                    </Button>

                                    <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="18" Margin="58,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="Last detected key" Foreground="{DynamicResource TextMuted}" />
                                            <TextBlock x:Name="LastKeyText" Text="Press 'Start Detect Keys' to begin" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource InfoBackground}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="58,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource PrimarySoftBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" Margin="0,0,16,0">
                                                <TextBlock Text="💡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="For a shorted Spacebar: add a block rule for Space, then add a remap rule from Right Alt to Space."
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="15"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="12,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <TextBlock Text="🛡" FontSize="32" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,16,0" />
                                        <StackPanel>
                                            <TextBlock Text="Saved protection" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock x:Name="RuleCountText" Text="0 block rules, 0 remap rules, 0 disabled keyboards" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Content="Open Rules Tab  ›" Click="OpenRulesTab_Click" Padding="22,15" FontSize="16" Margin="40,0,0,14" />
                                    <Button Content="Open Keyboards Tab  ›" Click="OpenKeyboardsTab_Click" Padding="22,15" FontSize="16" Margin="40,0,0,14" />
                                    <Button Content="Open Remap Tab  ›" Click="OpenRemapTab_Click" Padding="22,15" FontSize="16" Margin="40,0,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⌨  Keyboards" x:Name="KeyboardsTab">
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Connected keyboards" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Select the laptop keyboard or use detection mode to identify it by pressing a key. Refresh performs a hard driver scan."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,8,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh" Click="HardRefreshDevices_Click" />
                                    <Button Content="Detect by key press" Click="DetectDevice_Click" />
                                </StackPanel>
                            </StackPanel>
                            <ListBox x:Name="KeyboardList" DisplayMemberPath="DisplayName" SelectionChanged="KeyboardList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Selected keyboard" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock x:Name="SelectedDeviceText" Text="No keyboard selected" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,10" />
                                <TextBlock Text="Keyboard status" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock x:Name="SelectedDeviceStatusText" Text="Status: not selected" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,12" />
                                <TextBlock Text="Device path" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBox x:Name="DevicePathText" IsReadOnly="True" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                                    <Button Content="Disable Selected Keyboard" Click="DisableSelectedKeyboard_Click" />
                                    <Button Content="Enable Selected Keyboard" Click="EnableSelectedKeyboard_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                                <TextBlock Text="Safety: mouse devices are not selectable. The app also blocks disabling the last enabled detected keyboard."
                                           Foreground="{DynamicResource WarningText}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <DockPanel Grid.Row="2">
                                <TextBlock DockPanel.Dock="Top" Text="Fully disabled keyboards" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />
                                <ListView x:Name="DisabledKeyboardsList">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="330" />
                                            <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="90" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🛡  Rules" x:Name="RulesTab">
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.85*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Block broken key" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="Choose a keyboard, then capture or select the key that should be blocked."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,8,0,16" />
                            <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                            <ComboBox x:Name="RuleDeviceCombo" DisplayMemberPath="DisplayName" />
                            <TextBlock Text="Key to block" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0" />
                            <ComboBox x:Name="KeyCombo" DisplayMemberPath="Name" />
                            <TextBlock x:Name="CapturedKeyText" Text="No captured key yet" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,18">
                                <Button Content="Capture Key" Click="CaptureRuleKey_Click" />
                                <Button Content="Add Block Rule" Click="AddRule_Click" />
                            </StackPanel>
                            <Border Background="{DynamicResource InfoBackground}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                <TextBlock Text="Block rules only affect the selected physical keyboard when the Interception driver is loaded."
                                           Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saved Block Rules" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Remove Selected" Click="RemoveRule_Click" Margin="16,0,8,0" />
                                <Button Grid.Column="2" Content="Reset All" Click="ResetBlockRules_Click" Margin="0" />
                            </Grid>
                            <ListView Grid.Row="1" x:Name="RulesList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="300" />
                                        <GridViewColumn Header="Blocked key" DisplayMemberBinding="{Binding KeyName}" Width="150" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="90" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="⇄  Remap" x:Name="RemapTab">
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Remap healthy key" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="Map a healthy physical key to another key. Example: Right Alt becomes Space while the broken Spacebar stays blocked."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,8,0,16" />
                            <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                            <ComboBox x:Name="RemapDeviceCombo" DisplayMemberPath="DisplayName" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="From physical key" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                    <ComboBox x:Name="RemapFromKeyCombo" DisplayMemberPath="Name" />
                                    <TextBlock x:Name="RemapFromCapturedText" Text="From: not captured" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="To output key" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                    <ComboBox x:Name="RemapToKeyCombo" DisplayMemberPath="Name" />
                                    <TextBlock x:Name="RemapToCapturedText" Text="To: not captured" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                                <Button Content="Capture From" Click="CaptureRemapFromKey_Click" />
                                <Button Content="Capture To" Click="CaptureRemapToKey_Click" />
                                <Button Content="Add Remap Rule" Click="AddRemapRule_Click" />
                            </StackPanel>
                            <Border Background="{DynamicResource InfoBackground}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Quick preset for shorted Spacebar" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Creates: Block Space + Remap Right Alt to Space on the selected keyboard."
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,10" />
                                    <Button Content="Fix Broken Spacebar" Click="FixBrokenSpacebar_Click" Padding="16,10" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saved Remap Rules" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Remove Selected" Click="RemoveRemapRule_Click" Margin="16,0,8,0" />
                                <Button Grid.Column="2" Content="Reset All" Click="ResetRemapRules_Click" Margin="0" />
                            </Grid>
                            <ListView Grid.Row="1" x:Name="RemapRulesList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="260" />
                                        <GridViewColumn Header="From" DisplayMemberBinding="{Binding FromKeyName}" Width="130" />
                                        <GridViewColumn Header="To" DisplayMemberBinding="{Binding ToKeyName}" Width="130" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="90" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="⌁  Keyboard Tester">
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,4,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <TextBlock x:Name="TesterSelectedKeyboardText" Text="No keyboard selected" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock x:Name="TesterDropdownHintText" Text="Keyboard selection will appear here." Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" x:Name="TesterKeyboardCombo" DisplayMemberPath="DisplayName" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ToggleKeyboardTesterButton" Content="Start Testing" Click="ToggleKeyboardTester_Click" Padding="18,10" FontWeight="SemiBold" />
                                <Button x:Name="ResetKeyboardTesterButton" Content="Reset Test" Click="ResetKeyboardTester_Click" Padding="18,10" Margin="0" />
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TesterLastKeyText" Text="Press Start Testing, then press keys on the selected keyboard." FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" x:Name="TesterCountText" Text="0 visual key(s) tested" Foreground="{DynamicResource TextMuted}" Margin="18,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="KeyboardTesterLayoutPanel" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="⚙  Settings">
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="22" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="Application settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="These settings are stored in your Windows AppData folder. Enable Start with Windows only after confirming your rules work safely."
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16" />
                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" />
                        <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray when closing window" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,16" />
                        <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" Visibility="Collapsed">
                            <ComboBoxItem Content="Single Theme" Tag="Dark" />
                        </ComboBox>
                        <TextBlock Text="Backup &amp; Restore" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                            <Button Content="Export settings" Click="ExportSettings_Click" Padding="14,8" />
                            <Button Content="Import settings" Click="ImportSettings_Click" Padding="14,8" Margin="0" />
                        </StackPanel>
                        <TextBlock Text="Settings file" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                        <TextBox x:Name="SettingsPathText" IsReadOnly="True" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="☷  Dev Options">
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="Developer info" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Developer" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="Samslab (Samiul Hasan)" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource PanelBackground}" Padding="10,6" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="App Version" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="DevAppVersionText" Text="v1.0.0" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource PanelBackground}" Padding="10,6" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Repository" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="https://github.com/SamiulxHasanx07/key-disabler" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource PanelBackground}" Padding="10,6" />
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource FooterBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡" FontSize="26" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,12,0" />
                    <TextBlock Text="Key Disabler" FontSize="14" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="16" Padding="12,4" Background="{DynamicResource PrimarySoftBrush}">
                        <TextBlock x:Name="AppVersionText" Text="v1.0.0" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⊞" FontSize="26" Foreground="{DynamicResource TextMuted}" Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock x:Name="WindowsVersionText" Text="Windows" Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock x:Name="WindowsBuildText" Text="Build" Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◷" FontSize="26" Foreground="{DynamicResource TextMuted}" Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock Text="Uptime" Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock x:Name="UptimeText" Text="00h 00m 00s" Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="21" Background="{DynamicResource PrimarySoftBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0">
                        <TextBlock Text="🛡" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                    </Border>
                    <TextBlock x:Name="DriverFooterStatusText" Text="Driver Checking" Foreground="{DynamicResource TextPrimary}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
