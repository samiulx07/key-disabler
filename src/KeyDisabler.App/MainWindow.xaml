<Window x:Class="KeyDisabler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Key Disabler"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        Background="#F3F4F6"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Key Disabler" FontSize="30" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="Disable a full selected keyboard, or disable captured keys only on a selected keyboard. Mouse devices are never rule targets."
                               Foreground="#6B7280"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="999" Padding="14,8" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusPill" Text="Ready" Foreground="#1D4ED8" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="Transparent">
            <TabItem Header="Dashboard">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Current keyboard event" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Press any key from your laptop keyboard or external keyboard. The app will show which keyboard produced it and whether it was blocked."
                                       TextWrapping="Wrap"
                                       Foreground="#6B7280"
                                       Margin="0,8,0,16" />

                            <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Last detected key" Foreground="#6B7280" />
                                    <TextBlock x:Name="LastKeyText" Text="No key detected yet" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Use Capture Key to block any keyboard button, not only Space or Enter. Saved rules are restored only when the app is running."
                                       TextWrapping="Wrap"
                                       Foreground="#065F46"
                                       Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Saved protection" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock x:Name="RuleCountText" Text="0 key rules, 0 disabled keyboards" Foreground="#6B7280" Margin="0,8,0,16" />
                            <Button Content="Open Rules Tab" Click="OpenRulesTab_Click" Margin="0,0,0,8" />
                            <Button Content="Open Keyboards Tab" Click="OpenKeyboardsTab_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Keyboards" x:Name="KeyboardsTab">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Connected keyboards" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                                <TextBlock Text="Select the laptop keyboard or use detection mode to identify it by pressing a key."
                                           TextWrapping="Wrap"
                                           Foreground="#6B7280"
                                           Margin="0,8,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh" Click="RefreshDevices_Click" Margin="0,0,8,0" />
                                    <Button Content="Detect by key press" Click="DetectDevice_Click" />
                                </StackPanel>
                            </StackPanel>

                            <ListBox x:Name="KeyboardList" DisplayMemberPath="DisplayName" SelectionChanged="KeyboardList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Selected keyboard" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                                <TextBlock x:Name="SelectedDeviceText" Text="No keyboard selected" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,8,0,10" />

                                <TextBlock Text="Keyboard status" FontWeight="SemiBold" Foreground="#374151" />
                                <TextBlock x:Name="SelectedDeviceStatusText" Text="Status: not selected" Foreground="#6B7280" Margin="0,4,0,12" />

                                <TextBlock Text="Device path" FontWeight="SemiBold" Foreground="#374151" />
                                <TextBox x:Name="DevicePathText" IsReadOnly="True" TextWrapping="Wrap" Margin="0,4,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                                    <Button Content="Disable Selected Keyboard" Click="DisableSelectedKeyboard_Click" Margin="0,0,8,0" />
                                    <Button Content="Enable Selected Keyboard" Click="EnableSelectedKeyboard_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                                <TextBlock Text="Safety: mouse devices are not selectable. The app also blocks disabling the last enabled detected keyboard."
                                           Foreground="#991B1B"
                                           TextWrapping="Wrap" />
                            </Border>

                            <DockPanel Grid.Row="2">
                                <TextBlock DockPanel.Dock="Top" Text="Fully disabled keyboards" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10" />
                                <ListView x:Name="DisabledKeyboardsList">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="260" />
                                            <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="80" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Rules" x:Name="RulesTab">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Create key rule" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Choose a keyboard, then capture any key/button from that keyboard. Only that captured key on that selected physical keyboard will be blocked."
                                       TextWrapping="Wrap"
                                       Foreground="#6B7280"
                                       Margin="0,8,0,16" />

                            <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="#374151" />
                            <ComboBox x:Name="RuleDeviceCombo" DisplayMemberPath="DisplayName" />

                            <TextBlock Text="Key" FontWeight="SemiBold" Foreground="#374151" Margin="0,10,0,0" />
                            <ComboBox x:Name="KeyCombo" DisplayMemberPath="Name" />
                            <TextBlock x:Name="CapturedKeyText" Text="No captured key yet" Foreground="#6B7280" Margin="0,6,0,0" TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Capture Key" Click="CaptureRuleKey_Click" Margin="0,0,8,0" />
                                <Button Content="Add Key Rule" Click="AddRule_Click" Margin="0,0,8,0" />
                                <Button Content="Remove Selected" Click="RemoveRule_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Saved key rules" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14" />

                            <ListView x:Name="RulesList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="220" />
                                        <GridViewColumn Header="Key" DisplayMemberBinding="{Binding KeyName}" Width="130" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="90" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Border Background="White" CornerRadius="18" Padding="22" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Application settings" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                        <TextBlock Text="These settings are stored in your Windows AppData folder. Enable Start with Windows only after confirming your rules work safely."
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16" />

                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,10" />
                        <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray when closing window" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,16" />

                        <TextBlock Text="Settings file" FontWeight="SemiBold" Foreground="#374151" />
                        <TextBox x:Name="SettingsPathText" IsReadOnly="True" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="Ready" Foreground="#6B7280" Margin="4,16,0,0" />
    </Grid>
</Window>
