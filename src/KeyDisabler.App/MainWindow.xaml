<Window x:Class="KeyDisabler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Key Disabler"
        Width="1160"
        Height="800"
        MinWidth="980"
        MinHeight="680"
        Background="{DynamicResource WindowBackground}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Key Disabler" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock Text="Block broken keys, remap healthy keys, and test each physical keyboard safely. Mouse devices are never rule targets."
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource InfoBackground}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="8" Padding="14,8" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusPill" Text="Ready" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="Transparent">
            <TabItem Header="Dashboard">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Current keyboard event" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="Click 'Start Detect Keys' to monitor key presses. The app will show which keyboard produced the key and whether it was blocked."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,8,0,16" />

                            <Button x:Name="ToggleDetectKeysButton" Content="Start Detect Keys" Click="ToggleDashboardDetection_Click" Margin="0,0,0,16"
                                    Padding="18,10" FontWeight="SemiBold" />

                            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Last detected key" Foreground="{DynamicResource TextMuted}" />
                                    <TextBlock x:Name="LastKeyText" Text="Press 'Start Detect Keys' to begin" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="For a shorted Spacebar: add a block rule for Space, then add a remap rule from Right Alt to Space."
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSuccess}"
                                       Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Saved protection" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock x:Name="RuleCountText" Text="0 block rules, 0 remap rules, 0 disabled keyboards" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,16" />
                            <Button Content="Open Rules Tab" Click="OpenRulesTab_Click" Margin="0,0,0,8" />
                            <Button Content="Open Keyboards Tab" Click="OpenKeyboardsTab_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Keyboards" x:Name="KeyboardsTab">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Connected keyboards" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Select the laptop keyboard or use detection mode to identify it by pressing a key. Refresh performs a hard driver scan."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,8,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh" Click="HardRefreshDevices_Click" Margin="0,0,8,0" />
                                    <Button Content="Detect by key press" Click="DetectDevice_Click" />
                                </StackPanel>
                            </StackPanel>

                            <ListBox x:Name="KeyboardList" DisplayMemberPath="DisplayName" SelectionChanged="KeyboardList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Selected keyboard" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock x:Name="SelectedDeviceText" Text="No keyboard selected" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,10" />

                                <TextBlock Text="Keyboard status" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock x:Name="SelectedDeviceStatusText" Text="Status: not selected" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,12" />

                                <TextBlock Text="Device path" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBox x:Name="DevicePathText" IsReadOnly="True" TextWrapping="Wrap" Margin="0,4,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                                    <Button Content="Disable Selected Keyboard" Click="DisableSelectedKeyboard_Click" Margin="0,0,8,0" />
                                    <Button Content="Enable Selected Keyboard" Click="EnableSelectedKeyboard_Click" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                                <TextBlock Text="Safety: mouse devices are not selectable. The app also blocks disabling the last enabled detected keyboard."
                                           Foreground="{DynamicResource WarningText}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <DockPanel Grid.Row="2">
                                <TextBlock DockPanel.Dock="Top" Text="Fully disabled keyboards" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />
                                <ListView x:Name="DisabledKeyboardsList">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="260" />
                                            <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="80" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Rules" x:Name="RulesTab">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="1.05*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Block broken key" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Choose a keyboard, then capture/select the key that should be blocked. Use this for your shorted physical Spacebar."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,8,0,16" />

                                <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <ComboBox x:Name="RuleDeviceCombo" DisplayMemberPath="DisplayName" />

                                <TextBlock Text="Key to block" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0" />
                                <ComboBox x:Name="KeyCombo" DisplayMemberPath="Name" />
                                <TextBlock x:Name="CapturedKeyText" Text="No captured key yet" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,18">
                                    <Button Content="Capture Key" Click="CaptureRuleKey_Click" Margin="0,0,8,0" />
                                    <Button Content="Add Block Rule" Click="AddRule_Click" Margin="0,0,8,0" />
                                    <Button Content="Remove Selected" Click="RemoveRule_Click" />
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,20" />

                                <TextBlock Text="Remap healthy key" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Map a healthy physical key to another key. For your issue, Right Alt should become Space while the broken Spacebar stays blocked."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,8,0,16" />

                                <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <ComboBox x:Name="RemapDeviceCombo" DisplayMemberPath="DisplayName" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="From physical key" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                        <ComboBox x:Name="RemapFromKeyCombo" DisplayMemberPath="Name" />
                                        <TextBlock x:Name="RemapFromCapturedText" Text="From: not captured" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="To output key" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                        <ComboBox x:Name="RemapToKeyCombo" DisplayMemberPath="Name" />
                                        <TextBlock x:Name="RemapToCapturedText" Text="To: not captured" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                                    <Button Content="Capture From" Click="CaptureRemapFromKey_Click" Margin="0,0,8,0" />
                                    <Button Content="Capture To" Click="CaptureRemapToKey_Click" Margin="0,0,8,0" />
                                    <Button Content="Add Remap Rule" Click="AddRemapRule_Click" />
                                </StackPanel>

                                <Border Background="{DynamicResource InfoBackground}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Quick preset for shorted Spacebar" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Creates: Block Space + Remap Right Alt to Space on the selected keyboard."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,10" />
                                        <Button Content="Fix Broken Spacebar" Click="FixBrokenSpacebar_Click" Padding="16,10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Saved block rules" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />
                            <ListView Grid.Row="1" x:Name="RulesList" Margin="0,0,0,18">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="220" />
                                        <GridViewColumn Header="Blocked key" DisplayMemberBinding="{Binding KeyName}" Width="130" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="80" />
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="Saved remap rules" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                <Button Content="Remove Selected Remap" Click="RemoveRemapRule_Click" Margin="16,0,0,0" />
                            </StackPanel>
                            <ListView Grid.Row="3" x:Name="RemapRulesList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="190" />
                                        <GridViewColumn Header="From" DisplayMemberBinding="{Binding FromKeyName}" Width="110" />
                                        <GridViewColumn Header="To" DisplayMemberBinding="{Binding ToKeyName}" Width="110" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="80" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Keyboard Tester">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.75*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Keyboard Tester" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Select a keyboard, start testing, then press physical keys. The visual layout will highlight tested, blocked, and remapped keys."
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,8,0,14" />

                                <TextBlock x:Name="TesterSelectedKeyboardText" Text="No keyboard selected" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock x:Name="TesterDropdownHintText" Text="Keyboard selection will appear here." Foreground="{DynamicResource TextMuted}" Margin="0,4,0,8" TextWrapping="Wrap" />
                                <ComboBox x:Name="TesterKeyboardCombo" DisplayMemberPath="DisplayName" Margin="0,0,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button x:Name="ToggleKeyboardTesterButton" Content="Start Testing" Click="ToggleKeyboardTester_Click" Padding="18,10" FontWeight="SemiBold" Margin="0,0,8,0" />
                                    <Button x:Name="ResetKeyboardTesterButton" Content="Reset Test" Click="ResetKeyboardTester_Click" Padding="18,10" />
                                </StackPanel>

                                <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Last tested key" Foreground="{DynamicResource TextMuted}" />
                                        <TextBlock x:Name="TesterLastKeyText" Text="Press Start Testing, then press keys on the selected keyboard." FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,5,0,0" TextWrapping="Wrap" />
                                        <TextBlock x:Name="TesterCountText" Text="0 visual key(s) tested" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="KeyboardTesterLayoutPanel" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Test history" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12" />
                            <TextBlock DockPanel.Dock="Top" Text="Shows the latest key presses from the selected keyboard only."
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <ListView x:Name="TesterHistoryList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="70" />
                                        <GridViewColumn Header="Key" DisplayMemberBinding="{Binding Key}" Width="110" />
                                        <GridViewColumn Header="Scan" DisplayMemberBinding="{Binding ScanCode}" Width="60" />
                                        <GridViewColumn Header="Ext" DisplayMemberBinding="{Binding Extended}" Width="50" />
                                        <GridViewColumn Header="Action" DisplayMemberBinding="{Binding Action}" Width="130" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="22" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Application settings" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="These settings are stored in your Windows AppData folder. Enable Start with Windows only after confirming your rules work safely."
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,16" />

                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}" />
                        <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray when closing window" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimary}" />

                        <TextBlock Text="Theme" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                        <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" Margin="0,4,0,16">
                            <ComboBoxItem Content="System Default" Tag="System" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>

                        <TextBlock Text="Backup &amp; Restore" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                            <Button Content="Export settings" Click="ExportSettings_Click" Padding="14,8" Margin="0,0,8,0" />
                            <Button Content="Import settings" Click="ImportSettings_Click" Padding="14,8" Margin="0,0,8,0" />
                        </StackPanel>

                        <TextBlock Text="Settings file" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                        <TextBox x:Name="SettingsPathText" IsReadOnly="True" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Dev Options">
                <Border Background="{DynamicResource CardBackground}" CornerRadius="18" Padding="26" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Background="{DynamicResource DevOptionsBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20" Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image x:Name="AboutLogoImage" Width="78" Height="78" Stretch="Uniform" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Key" FontSize="34" FontWeight="Bold" Foreground="{DynamicResource BrandRed}" />
                                        <TextBlock Text=" Disabler" FontSize="34" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                    <TextBlock Text="Device-specific keyboard control utility" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Developed by" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" />
                        <TextBlock Text="Samslab (Samiul Hasan)" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,4,0,18" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="GitHub" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="https://github.com/SamiulxHasanx07" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource WindowBackground}" Padding="10,6" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Email" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="samiulxhasan650@gmail.com" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource WindowBackground}" Padding="10,6" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Phone" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="+8801788058690" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource WindowBackground}" Padding="10,6" />
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="Ready" Foreground="{DynamicResource TextMuted}" Margin="4,16,0,0" />
    </Grid>
</Window>
