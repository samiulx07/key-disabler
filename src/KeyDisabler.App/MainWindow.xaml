<Window x:Class="KeyDisabler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Key Disabler"
        Width="980"
        Height="680"
        MinWidth="840"
        MinHeight="560"
        Background="#F3F4F6"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Key Disabler" FontSize="30" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="Standalone Windows utility for keyboard detection, saved rules, and future per-device key enforcement."
                               Foreground="#6B7280"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="999" Padding="14,8" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusPill" Text="Ready" Foreground="#1D4ED8" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="Transparent">
            <TabItem Header="Dashboard">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Current keyboard event" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Press any key from your laptop keyboard or external keyboard. The app will show which device produced it."
                                       TextWrapping="Wrap"
                                       Foreground="#6B7280"
                                       Margin="0,8,0,16" />

                            <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="14" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Last detected key" Foreground="#6B7280" />
                                    <TextBlock x:Name="LastKeyText" Text="No key detected yet" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Note: this version saves rules and detects per-device input. The driver/service layer will be added next for actual system-wide enforcement."
                                       TextWrapping="Wrap"
                                       Foreground="#92400E"
                                       Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Saved rules" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock x:Name="RuleCountText" Text="0 rules saved" Foreground="#6B7280" Margin="0,8,0,16" />
                            <Button Content="Open Rules Tab" Click="OpenRulesTab_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Keyboards">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Connected keyboards" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                                <TextBlock Text="Select the laptop keyboard or use detection mode to identify it by pressing a key."
                                           TextWrapping="Wrap"
                                           Foreground="#6B7280"
                                           Margin="0,8,0,12" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh" Click="RefreshDevices_Click" />
                                    <Button Content="Detect by key press" Click="DetectDevice_Click" />
                                </StackPanel>
                            </StackPanel>

                            <ListBox x:Name="KeyboardList" DisplayMemberPath="DisplayName" SelectionChanged="KeyboardList_SelectionChanged" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Selected keyboard" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock x:Name="SelectedDeviceText" Text="No keyboard selected" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,8,0,18" />

                            <TextBlock Text="Device path" FontWeight="SemiBold" Foreground="#374151" />
                            <TextBox x:Name="DevicePathText" IsReadOnly="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Rules" x:Name="RulesTab">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="18" Padding="22" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Create rule" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                            <TextBlock Text="Choose a keyboard and a key. Settings are saved locally and restored after restart."
                                       TextWrapping="Wrap"
                                       Foreground="#6B7280"
                                       Margin="0,8,0,16" />

                            <TextBlock Text="Keyboard" FontWeight="SemiBold" Foreground="#374151" />
                            <ComboBox x:Name="RuleDeviceCombo" DisplayMemberPath="DisplayName" />

                            <TextBlock Text="Key" FontWeight="SemiBold" Foreground="#374151" />
                            <ComboBox x:Name="KeyCombo" DisplayMemberPath="Name" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Add Rule" Click="AddRule_Click" />
                                <Button Content="Remove Selected" Click="RemoveRule_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="22" Margin="12,0,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Saved rules" FontSize="20" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,14" />

                            <ListView x:Name="RulesList">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Keyboard" DisplayMemberBinding="{Binding DeviceName}" Width="220" />
                                        <GridViewColumn Header="Key" DisplayMemberBinding="{Binding KeyName}" Width="130" />
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding IsEnabled}" Width="90" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Border Background="White" CornerRadius="18" Padding="22" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Application settings" FontSize="20" FontWeight="SemiBold" Foreground="#111827" />
                        <TextBlock Text="These settings are stored in your Windows AppData folder."
                                   Foreground="#6B7280"
                                   Margin="0,8,0,16" />

                        <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,10" />
                        <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray when closing window" Checked="SettingsCheck_Changed" Unchecked="SettingsCheck_Changed" Margin="0,0,0,16" />

                        <TextBlock Text="Settings file" FontWeight="SemiBold" Foreground="#374151" />
                        <TextBox x:Name="SettingsPathText" IsReadOnly="True" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" x:Name="FooterText" Text="Ready" Foreground="#6B7280" Margin="4,16,0,0" />
    </Grid>
</Window>
